# Enable URL rewriting
RewriteEngine On

# Set website homepage to new_home.php
RewriteRule ^$ new_home.php [L]
RewriteRule ^blogs/?$ new-blog-page.php [NC,L,QSA]

# Handle blog detail URLs: /blogs/slug-name -> blog-detail.php?slugurl=slug-name
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^blogs/([^/]+)/?$ blog-detail.php?slugurl=$1 [NC,L,QSA]

# Project clean URL: /saya-biztop -> new project page (biztop variant)
RewriteRule ^saya-biztop/?$ new-project-page.php?project=saya-biztop [NC,L,QSA]
RewriteRule ^saya-piazza/?$ new-project-page.php?project=saya-piazza [NC,L,QSA]
RewriteRule ^saya-gold-avenue/?$ new-project-page.php?project=gold-avenue [NC,L,QSA]
RewriteRule ^saya-zion/?$ new-project-page.php?project=saya-zion [NC,L,QSA]
RewriteRule ^saya-zenith/?$ new-project-page.php?project=saya-zenith [NC,L,QSA]
RewriteRule ^saya-desire-residency/?$ new-project-page.php?project=saya-desire-residency [NC,L,QSA]
RewriteRule ^saya-southx/?$ new-project-page.php [NC,L,QSA]
RewriteRule ^in-the-media/?$ new_media-page.php [NC,L,QSA]
RewriteRule ^events/?$ new_media-page.php?page=event [NC,L,QSA]
RewriteRule ^contact-us/?$ new_media-page.php?page=contact [NC,L,QSA]
RewriteRule ^careers/?$ new_media-page.php?page=career [NC,L,QSA]
RewriteRule ^about-us/?$ new_home.php?about=1 [NC,L,QSA]

# Remove .php extension from URLs
# If the request is for a file that exists without .php extension, serve it
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

# Optional: Redirect .php extension to clean URL (prevents duplicate content)
# Uncomment the following lines if you want to force clean URLs
# RewriteCond %{THE_REQUEST} /([^.]+)\.php [NC]
# RewriteRule ^ /%1 [NC,L,R=301]

# ============================================
# PERFORMANCE OPTIMIZATION - Cache Headers
# ============================================

# Enable compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml
</IfModule>

# Browser Caching - Images, CSS, JS, Fonts
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Images
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    
    # CSS and JavaScript
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/x-javascript "access plus 1 month"
    
    # Fonts
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    
    # HTML
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Cache-Control Headers
<IfModule mod_headers.c>
    # Cache static assets for 1 year
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico|css|js|woff|woff2|ttf|otf|eot)$">
        Header set Cache-Control "max-age=31536000, public, immutable"
    </FilesMatch>
    
    # Don't cache HTML files
    <FilesMatch "\.(html|htm|php)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
</IfModule>






