<IfModule mod_rewrite.c>
RewriteEngine On

# --- Force HTTPS + non-www ---
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteRule ^ https://sayahomes.com%{REQUEST_URI} [L,R=301]

# --- Redirect .php URLs to extensionless (e.g., /about.php -> /about) ---
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/([^/]+)\.php [NC]
RewriteRule ^ /%1 [R=301,L] 

# --- Internally rewrite extensionless URLs to .php files ---
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^/]+)/?$ $1.php [L]

# --- SEO-friendly URLs for blogs ---
RewriteRule ^blogs/([a-zA-Z0-9-]+)/?$ blog-detail.php?slugurl=$1 [L,QSA]

# --- SEO-friendly URLs for events ---
RewriteRule ^events/([a-zA-Z0-9-]+)/?$ event-details.php?ev_group=$1 [L,QSA]
</IfModule>

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php80” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php80 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
