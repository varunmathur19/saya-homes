RewriteEngine On

# Redirect .php URLs to extensionless
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/([^/.]+)\.php [NC]
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ /%1 [R=301,L]

# Internally rewrite extensionless URLs to .php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([^/]+)$ $1.php [L]